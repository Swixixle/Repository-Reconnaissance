# Run outputs — never commit these
out/
tmp/
temp/
output/
attached_assets/

# Environment
.env
.env.local
.env.production
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
.venv/
venv/
*.egg-info/
dist/
build/
.pytest_cache/

# Node
node_modules/
# Legacy local CLI shim (active entry is server/cli.ts via ts-node)
server/cli.js
dist/
# Bundled GitHub Action (see .github/debrief-action)
!/.github/debrief-action/dist/
.next/
.turbo/

# Tauri build output
client/src-tauri/target/

# Database
*.db
*.sqlite
*.sqlite3

# Logs
*.log
logs/
*.ndjson

# OS
.DS_Store
Thumbs.db

# IDE — track shared Cursor project rule; ignore other `.cursor/` local state
.cursor/*
!.cursor/rules/
!.cursor/rules/debrief.mdc
.vscode/settings.json
.idea/

# Test artifacts
.coverage
htmlcov/

# Vite / tooling
vite.config.ts.*
*.tar.gz
*.swp

# Prevent accidental nested git repos in test fixtures
**/fixtures/**/.git
**/tmp/**
**/monitor/**/.git
