# ─── LLM ────────────────────────────────────────────────
# OpenAI and compatible APIs (Python analyzer + optional Replit helpers)
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
# Also read by tooling:
OPENAI_API_KEY=
DEBRIEF_OPENAI_API_KEY=
DEBRIEF_ANALYZER_MODEL=gpt-4.1

# ─── Server ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development
HOST=0.0.0.0
LOG_LEVEL=info
APP_URL=http://localhost:5000

# Python subprocess for analyzer
PYTHON_EXEC_PATH=python3
ANALYZER_TIMEOUT_MS=600000

# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://debrief:debrief@localhost:5432/debrief

# ─── Queue (BullMQ / Redis) ──────────────────────────────
REDIS_URL=redis://localhost:6379
DEBRIEF_USE_BULLMQ=0
DEBRIEF_RUN_ANALYZER_WORKER=

# ─── Auth (Clerk) ────────────────────────────────────────
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ─── Billing (Stripe) ────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_BUILDER=price_...
STRIPE_PRICE_STUDIO=price_...
STRIPE_PRICE_UNLIMITED=price_...
DEBRIEF_BILLING_ACTIVE=0

# ─── Chain / Evidence Trail ──────────────────────────────
# Requires `npm run db:push` when enabling new tables locally.
DEBRIEF_CHAIN_ENABLED=true
PTA_CHAIN_STATE_DIR=
DEBRIEF_CHAIN_HMAC_SECRET=
# Optional Ed25519 (PEM). Public key required for verification.
DEBRIEF_CHAIN_SIGNING_PRIVATE_KEY=
DEBRIEF_CHAIN_SIGNING_PUBLIC_KEY=
DEBRIEF_CHAIN_EXPORT_PRIVATE_KEY=

# ─── Scheduler ───────────────────────────────────────────
DEBRIEF_SCHEDULER_ENABLED=false
DEBRIEF_SCHEDULER_TIMEZONE=UTC

# Anomaly / email alerts (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── Desktop (Tauri) ─────────────────────────────────────
DEBRIEF_ALLOW_LOCAL_PATHS=0

# ─── CORS / Access ───────────────────────────────────────
# Comma-separated browser origins allowed to call the API (e.g. https://app.example.com,http://localhost:5173).
# In production, if this is unset or empty, the server logs a [SECURITY] warning and does not reflect Access-Control-Allow-Origin for cross-origin requests (browser calls from other origins are blocked).
ALLOWED_ORIGINS=

# API guard (optional in dev)
API_KEY=
ADMIN_KEY=
# Public browser deploy: skip shared X-Api-Key on ingest/project APIs (still rate-limited).
DEBRIEF_OPEN_WEB=0
# Must match production build so the SPA omits the key field (Vite).
VITE_DEBRIEF_OPEN_WEB=false
