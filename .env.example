# Required – Application
PORT=3000                # int – HTTP server port
NODE_ENV=development     # string – development | production

# Required – Python Integration
PYTHON_EXEC_PATH=python3 # string – path to Python interpreter
ANALYZER_TIMEOUT_MS=30000 # int – max runtime for Python process

# Required – Database
DATABASE_URL=postgres://user:pass@localhost:5432/app  # string – PostgreSQL connection URI

# Required – Redis (used by the background worker)
REDIS_URL=redis://localhost:6379  # string – Redis connection URI

# Optional – Logging
LOG_LEVEL=info           # string – log verbosity (optional)

# Optional – Worker mode (set to "1" on the background worker service only)
DEBRIEF_RUN_ANALYZER_WORKER=  # string – set to "1" to run as analyzer worker instead of web server
